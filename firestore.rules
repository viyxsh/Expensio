rules_version = '2';

// Phase 1 security rules — member-only access. Verify in the emulator before
// deploying (see SETUP.md). Tighten the `users` collection in Phase 2.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function groupMembers(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    // Placeholder + account user profiles. Loose for Phase 1 (any signed-in
    // user); restrict to shared-group members in Phase 2.
    match /users/{userId} {
      allow read, write: if signedIn();
    }

    // A group is readable/editable only by its members.
    match /groups/{groupId} {
      allow read, update, delete:
        if signedIn() && uid() in resource.data.memberIds;
      allow create:
        if signedIn() && uid() in request.resource.data.memberIds;
    }

    // Expenses carry a `visibleTo` array (participants + payer, or [owner] for
    // personal). Only those users may read/write.
    match /expenses/{expenseId} {
      allow read, update, delete:
        if signedIn() && uid() in resource.data.visibleTo;
      allow create:
        if signedIn() && uid() in request.resource.data.visibleTo;
    }

    // Settlements carry a denormalized `memberIds` (the group's members) so they
    // can be queried per-user and gated without an extra group lookup on read.
    match /settlements/{settlementId} {
      allow read, update, delete:
        if signedIn() && uid() in resource.data.memberIds;
      allow create:
        if signedIn() && uid() in groupMembers(request.resource.data.groupId);
    }
  }
}
